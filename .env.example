# ─────────────────────────────────────────────────────────────
# TaskPilot configuration. Copy to `.env` and fill in.
# Defaults are safe + offline: rule-based planner, in-memory store,
# mock connectors, and MANUAL approval for irreversible actions.
# ─────────────────────────────────────────────────────────────

# Planner: stub (offline rule-based) | openai
LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
TEMPERATURE=0.1
MAX_STEPS=8

# Memory: memory | redis
MEMORY_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
MEMORY_TTL_SECONDS=604800

# Approvals: manual (pause + resume) | auto (approve all) | deny (reject all)
APPROVAL_MODE=manual

# Connectors: mock (built-in simulation) | real (via MCP servers)
CONNECTOR_MODE=mock
SLACK_BOT_TOKEN=
GMAIL_CREDENTIALS_PATH=
NOTION_API_KEY=

# MCP: path to a JSON file describing MCP servers (see examples/mcp_config.example.json)
MCP_CONFIG_PATH=
